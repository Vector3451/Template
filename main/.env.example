# Copy to .env.local — never commit real values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=E-Commerce

# Database
# Run: npx prisma postgres link --database "your-database-id"
# Or for local Postgres: DATABASE_URL="postgresql://user:pass@localhost:5432/dbname"
DATABASE_URL=

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# NextAuth
# Generate a random secret: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (see README.md for setup instructions)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
